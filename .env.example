POSTGRES_DB=cms
POSTGRES_USER=cms
POSTGRES_PASSWORD=change-me

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_USE_X_FORWARDED_PROTO=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

NUXT_PUBLIC_TRACKNODE_API_KEY=
NUXT_PUBLIC_TRACKNODE_TRACKER_SRC=https://tracknode.ru/tracker.js
NUXT_PUBLIC_API_BASE=https://example.com
NUXT_INTERNAL_API_BASE=http://backend:8000

NGINX_HTTP_PORT=80
